# Copy to apps/api/.env and fill in. .env is git-ignored.

PORT=8080

# --- Gemini backend selection ---
# "vertex"   : Vertex AI on Google Cloud, authed via Application Default
#              Credentials (run `gcloud auth application-default login`). No key.
# "aistudio" : Gemini Developer API with an AIza key from aistudio.google.com.
GEMINI_BACKEND=vertex
GEMINI_MODEL=gemini-2.5-flash

# Required when GEMINI_BACKEND=vertex:
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Required when GEMINI_BACKEND=aistudio (https://aistudio.google.com/apikey):
GEMINI_API_KEY=
