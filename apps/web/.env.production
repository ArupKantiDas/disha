# Production build env (loaded by Next when NODE_ENV=production).
# The Cloud Run API URL is public and CORS-open, so it's safe to commit.
NEXT_PUBLIC_API_URL=https://disha-api-563892064515.asia-south1.run.app

# Firebase web config is injected at build time from Vercel env vars (Project
# Settings -> Environment Variables), not committed here. Firebase web API keys
# are public by design, but we keep them out of the repo for clean hygiene and
# restrict the key to auth-only APIs in Google Cloud. For local dev, copy them
# into apps/web/.env.local (git-ignored) — see .env.local.example.
